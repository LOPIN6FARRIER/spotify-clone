---
import type { Playlist } from "@/lib/data";
import { CardPlayButton } from "@/components/CardPlayButton";

interface Props {
  playlist: Playlist;
  isAdmin?: boolean;
}

const { playlist, isAdmin = false } = Astro.props;
const { id, cover, title, artists, local = false } = playlist;

const artistsString = artists.join(", ");
---

<article
  class="group relative rounded-md overflow-hidden
hover:bg-zinc-800 shadow-lg hover:shadow-xl bg-zinc-500/30
transition-all duration-300"
>
  {
    local && (
      <div class="absolute top-4 -right-8 bg-green-500 text-white text-xs font-bold px-10 py-1 rotate-45 transform z-20 shadow-lg">
        LOCAL
      </div>
    )
  }

  <div
    class=`absolute right-4 bottom-20 translate-y-4 
  transition-all duration-500 opacity-0
  group-hover:translate-y-0 group-hover:opacity-100 z-10`
  >
    {local && <CardPlayButton client:visible id={id} />}
  </div>

  {
    isAdmin && !local && (
      <a
        href={`/playlist/${id}/edit`}
        class="admin-edit-icon"
        title="Editar playlist"
        onclick="event.stopPropagation()"
      >
        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
          <path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z" />
        </svg>
      </a>
    )
  }

  <a
    href={`/playlist/${id}`}
    class="playList-item transition-all duration-300 flex relative p-2 overflow-hidden gap-2 pb-6 w-44 flex-col"
    transition:name=`playList ${id} box`
  >
    <pictture class="aspect-square w-full h-auto flex-none">
      <img
        src={cover}
        alt={`cover of ${title} by ${artistsString}`}
        class="objet-cover w-full h-full rounded-md"
        transition:name=`playList ${id} image`
      />
    </pictture>
    <div class="flex flex-auto flex-col px-2">
      <h4 transition:name=`playlist ${id} title` class="text-white text-sm">
        {title}
      </h4>
      <span
        transition:name=`playlist ${id} artists`
        class="text-xs text-gray-400"
      >
        {artistsString}
      </span>
    </div>
  </a>
</article>

<style>
  .admin-edit-icon {
    position: absolute;
    top: 8px;
    left: 8px;
    background: rgba(29, 185, 84, 0.95);
    color: #000;
    padding: 8px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: all 0.2s;
    z-index: 30;
  }

  article:hover .admin-edit-icon {
    opacity: 1;
  }

  .admin-edit-icon:hover {
    background: #1ed760;
    transform: scale(1.1);
  }
</style>
