---
import LibraryIcon from "../icons/Library.astro";
import HomeIcon from "../icons/Home.astro";
import SearchIcon from "../icons/Search.astro";
import SideMenuItem from "./SideMenuItem.astro";
import { PlaylistList } from "./PlaylistList";
import UserProfile from "./UserProfile.astro";

const user = Astro.locals.user;
const isAdmin = user?.role === "admin";
---

<nav class="flex flex-col flex-1 gap-2">
  <UserProfile />
  <div class="bg-zinc-900 rounded-lg gap-2">
    <ul>
      <SideMenuItem href="/">
        <HomeIcon />
        Inicio
      </SideMenuItem>
      <SideMenuItem href="/search">
        <SearchIcon />
        Buscar
      </SideMenuItem>
      {
        isAdmin && (
          <SideMenuItem href="/admin">
            <svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor">
              <path d="M10.09 15.59L11.5 17l5-5-5-5-1.41 1.41L12.67 11H3v2h9.67l-2.58 2.59zM19 3H5c-1.11 0-2 .9-2 2v4h2V5h14v14H5v-4H3v4c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2z" />
            </svg>
            Admin Panel
          </SideMenuItem>
        )
      }
    </ul>
    <div class="bg-zinc-900 rounded-lg gap-2 flex-1">
      <ul>
        <SideMenuItem href="/#">
          <LibraryIcon />
          Tu Biblioteca
        </SideMenuItem>
        <PlaylistList client:load />
      </ul>
    </div>
  </div>
</nav>
